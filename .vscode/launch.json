{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Streamlit",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "console": "integratedTerminal",
      "args": ["run", "${file}", "--server.port", "8500"],
      "jinja": true,
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false
    },
    {
      "name": "Python Debugger: Chainlit",
      "type": "debugpy",
      "request": "launch",
      "module": "chainlit",
      "console": "integratedTerminal",
      "args": ["run", "${file}", "--port", "9500", "-w"],
      "jinja": true,
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false
    },
    {
      "name": "Python Debugger: FastAPI",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "console": "integratedTerminal",
      "args": ["server.app:app", "--reload", "--reload-dir", "server", "--host", "0.0.0.0", "--port", "8000" ],
      "cwd": "${workspaceFolder}/databricks-builder-app",
      "jinja": true,
      "envFile": "${workspaceFolder}/databricks-builder-app/.env.local",
      "justMyCode": false
    },
    {
      "name": "Server :: AI Playground",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "console": "integratedTerminal",
      "args": ["server.app:app", "--reload", "--reload-dir", "server", "--host", "0.0.0.0", "--port", "8000" ],
      "cwd": "${workspaceFolder}/databricks-builder-app",
      "jinja": true,
      "envFile": "${workspaceFolder}/databricks-builder-app/.env.local",
      "justMyCode": false
    },
    {
      "name": "GUI :: AI Playground",
      "request": "launch",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "runtimeExecutable": "npm",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "type": "node",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/databricks-builder-app/client",
    },
    {
      "name": "Python Debugger: Flask",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "console": "integratedTerminal",
      "env": { "FLASK_APP": "${file}", "FLASK_DEBUG": "1" },
      "args": ["run", "--no-debugger", "--no-reload","--host=0.0.0.0", "--port=5000"],
      "jinja": true,
      "autoStartBrowser": false,
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false
    },
    {
      "name": "Python Debugger: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false
    },
    {
      "name": "Python Debugger: Current File with Arguments",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "args": "${command:pickArgs}",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false
    },
    {
      "name": "Test & Debug : bd-notebooks-module",
      "type": "debugpy",
      "request": "launch",
      "purpose": [
        "debug-test"
      ],
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/src/test/py",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false
    }
  ]
}
