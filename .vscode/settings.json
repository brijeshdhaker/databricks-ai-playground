{
    "python.envFile": "${workspaceFolder}/.env",
    "python-envs.defaultEnvManager": "ms-python.python:venv",
    "python-envs.defaultPackageManager": "ms-python.python:pip",
    "python.autoComplete.extraPaths": [
        "${workspaceFolder}/databricks-tools-core",
        "${workspaceFolder}/databricks-mcp-server",
        "${workspaceFolder}/databricks-builder-app"
    ],
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.autoImportCompletions": true,
    "python.analysis.extraPaths": [
        "${workspaceFolder}/databricks-tools-core",
        "${workspaceFolder}/databricks-mcp-server",
        "${workspaceFolder}/databricks-builder-app"
    ],
    "jupyter.notebookFileRoot": "${workspaceFolder}",
    "python.terminal.useEnvFile": true,
    "python.terminal.activateEnvironment": true,
    "terminal.integrated.env.linux": {
        "PYTHONPATH": "${workspaceFolder}/databricks-tools-core:${workspaceFolder}/databricks-mcp-server:${workspaceFolder}/databricks-builder-app:${env:PYTHONPATH}"
    },
    "python.testing.autoTestDiscoverOnSaveEnabled": true,
    //"python.testing.cwd": "${workspaceFolder}",
    "python.testing.pytestEnabled": true,
    "python.testing.pytestArgs": [
        //"${workspaceFolder}"
    ],
    "python.testing.unittestEnabled": false,
    "python.testing.unittestArgs": [
        "-v", "-s", "${workspaceFolder}", "-p", "Test*.py"
    ],
    "postman.settings.dotenv-detection-notification-visibility": false,
    "chat.mcp.discovery.enabled": {
        "claude-desktop": true,
        "windsurf": true,
        "cursor-global": true,
        "cursor-workspace": true
    },

    "claudeCode.initialPermissionMode": "plan",
    "claudeCode.useTerminal": false,
    "claudeCode.respectGitIgnore": true,
    "claudeCode.enableNewConversationShortcut": true,
    "claudeCode.enableReopenClosedSessionShortcut": true,
    "claudeCode.environmentVariables":[
        {
        "name": "ANTHROPIC_BASE_URL",
        "value": "http://hostmaster.sandbox.net:11434"
        },
        {
        "name": "ANTHROPIC_AUTH_TOKEN",
        "value": "dapi.."
        },
        {
        "name": "ANTHROPIC_MODEL",
        "value": "gemma4:12b-it-qat"
        },
        {
        "name": "ANTHROPIC_CUSTOM_HEADERS",
        "value": "x-databricks-use-coding-agent-mode: true"
        },
        {
        "name": "ANTHROPIC_DEFAULT_OPUS_MODEL",
        "value": "claude-opus-4-6"
        },
        {
        "name": "ANTHROPIC_DEFAULT_SONNET_MODEL",
        "value": "claude-sonnet-4-6"
        },
        {
        "name": "ANTHROPIC_DEFAULT_HAIKU_MODEL",
        "value": "claude-haiku-4-5"
        }
    ],
    
    "jupyter.interactiveWindow.cellMarker.codeRegex": "^# COMMAND ----------|^# Databricks notebook source|^(#\\s*%%|#\\s*\\<codecell\\>|#\\s*In\\[\\d*?\\]|#\\s*In\\[ \\])",
    "jupyter.interactiveWindow.cellMarker.default": "# COMMAND ----------",
}
